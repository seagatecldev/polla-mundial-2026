# ============================================================================
#  Polla Mundial — Configuración por cliente (white-label)
#  Copia este archivo a ".env.local" y completa los valores de cada cliente.
#  Las NEXT_PUBLIC_* se "hornean" en el build (cada cliente compila su build).
#  Si omites una variable, se usa el valor por defecto (versión empresa Seagate).
# ============================================================================

# --- Supabase (OBLIGATORIO) — del panel del proyecto del cliente ------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Administrador ----------------------------------------------------------
# El correo que controla el panel /admin (quien se registre con él será admin).
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

# --- Marca / textos ---------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Polla Mundial 2026"
NEXT_PUBLIC_APP_TAGLINE="Predice, acierta y gana."
NEXT_PUBLIC_APP_DESCRIPTION="Torneo de predicciones: predice los marcadores, gana puntos y compite en el ranking."

# --- Logos (archivos en /public) --------------------------------------------
# Sube los logos a la carpeta public/ y referencia su ruta aquí.
# Deja NEXT_PUBLIC_LOGO_SECONDARY vacío para mostrar un solo logo.
NEXT_PUBLIC_LOGO_PRIMARY="/logo.png"
NEXT_PUBLIC_LOGO_PRIMARY_ALT="Logo"
NEXT_PUBLIC_LOGO_SECONDARY=
NEXT_PUBLIC_LOGO_SECONDARY_ALT=

# --- Colores de marca (hex) -------------------------------------------------
# Color principal (botones, menú activo, cabeceras) y sus variantes.
NEXT_PUBLIC_COLOR_PRIMARY="#152C5B"
NEXT_PUBLIC_COLOR_PRIMARY_DARK="#0D1C3D"
NEXT_PUBLIC_COLOR_PRIMARY_LIGHT="#4F7AD1"
# Acento (rojo de errores/En vivo) y dorado (detalles). Opcionales.
NEXT_PUBLIC_COLOR_ACCENT="#C8102E"
NEXT_PUBLIC_COLOR_ACCENT_DARK="#9E0C24"
NEXT_PUBLIC_COLOR_GOLD="#C9A227"
NEXT_PUBLIC_COLOR_GOLD_DARK="#A8851C"

# --- Funcionalidades --------------------------------------------------------
# Registro restringido por cédula (lista blanca de empleados).
#   "true"  = versión empresa (requiere cédula válida; aplica trigger_con_cedula.sql)
#   "false" = registro abierto por nombre (aplica trigger_abierto.sql)
NEXT_PUBLIC_REQUIRE_CEDULA=false

# --- Cuenta de demostración (opcional) --------------------------------------
# Si se definen, el login aparece pre-rellenado con estas credenciales para que
# el visitante solo pulse "Entrar". Úsalo solo en una instancia de demo con una
# cuenta desechable (no admin). Déjalas vacías en producción.
NEXT_PUBLIC_DEMO_EMAIL=
NEXT_PUBLIC_DEMO_PASSWORD=
